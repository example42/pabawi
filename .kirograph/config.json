{
  "version": 1,
  "languages": [],
  "include": [],
  "exclude": [
    "node_modules/**",
    "dist/**",
    "build/**",
    ".git/**",
    "*.min.js",
    ".kirograph/**"
  ],
  "maxFileSize": 1048576,
  "extractDocstrings": true,
  "trackCallSites": true,
  "enableEmbeddings": true,
  "embeddingModel": "nomic-ai/nomic-embed-text-v1.5",
  "embeddingDim": 768,
  "useVecIndex": false,
  "semanticEngine": "pglite",
  "typesenseDashboard": false,
  "qdrantDashboard": false,
  "minLogLevel": "warn",
  "frameworkHints": [
    "express",
    "svelte"
  ],
  "fuzzyResolutionThreshold": 0.5,
  "enableArchitecture": true,
  "cavemanMode": "lite"
}