# =============================================================================
# Pabawi — env file for the PostgreSQL test stack
# =============================================================================
# Consumed by scripts/docker-postgres-test.compose.yml via the
# scripts/docker-postgres-test.sh harness. Not for production use.
# =============================================================================

# -----------------------------------------------------------------------------
# Compose substitution (host-side)
# -----------------------------------------------------------------------------
# Host port mappings — chosen to avoid collisions with the default
# docker-compose.yml stack (3000 / 5432). HOST_APP_PORT is read by
# docker-compose.yml and only used for the host-side port mapping; the
# app inside the container always binds to 3000.
HOST_APP_PORT=3001
POSTGRES_PORT=5433

# Postgres service credentials (used both by the postgres service and in
# the DATABASE_URL below).
POSTGRES_USER=pabawi
POSTGRES_PASSWORD=pabawi  # pragma: allowlist secret
POSTGRES_DB=pabawi

# -----------------------------------------------------------------------------
# Application (container-side env)
# -----------------------------------------------------------------------------
# App binds to 3000 inside the container; host port mapping lives in
# docker-postgres-test.compose.yml.
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=debug

# JWT_SECRET must be >= 32 chars and not a placeholder. Local-test only.
JWT_SECRET=local-postgres-test-jwt-secret-do-not-use-in-prod-9f3a2c  # pragma: allowlist secret

ALLOW_DESTRUCTIVE_PROVISIONING=false

# -----------------------------------------------------------------------------
# Database — PostgreSQL backend
# -----------------------------------------------------------------------------
DB_TYPE=postgres
# `postgres` is the service name on the pgtest network. The user:password
# pair below matches POSTGRES_USER/POSTGRES_PASSWORD on the test postgres
# service and is not used outside this ephemeral test stack.
DATABASE_URL=postgres://pabawi:pabawi@postgres:5432/pabawi  # pragma: allowlist secret
# DATABASE_PATH is unused under DB_TYPE=postgres (the entrypoint skips
# SQLite provisioning entirely). Left commented for clarity.
# DATABASE_PATH=/opt/pabawi/data/pabawi.db

# -----------------------------------------------------------------------------
# Command execution
# -----------------------------------------------------------------------------
COMMAND_WHITELIST_ALLOW_ALL=false
COMMAND_WHITELIST=["ls","pwd","whoami","uptime"]
BOLT_PROJECT_PATH=/opt/pabawi/bolt-project
BOLT_EXECUTION_TIMEOUT=300000

# -----------------------------------------------------------------------------
# Integrations — all disabled
# -----------------------------------------------------------------------------
PUPPETDB_ENABLED=false
PUPPETSERVER_ENABLED=false
HIERA_ENABLED=false
ANSIBLE_ENABLED=false
SSH_ENABLED=false
PROXMOX_ENABLED=false
AWS_ENABLED=false
AZURE_ENABLED=false
MCP_ENABLED=false
